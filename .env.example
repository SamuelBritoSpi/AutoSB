# CONFIGURAÇÃO DO FIREBASE (PÚBLICO - LADO DO CLIENTE)
# Obtenha estes valores no Console do Firebase > Configurações do Projeto
NEXT_PUBLIC_FIREBASE_API_KEY=sua_chave_aqui
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=seu-projeto.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=seu-projeto-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=seu-projeto.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=seu_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=seu_app_id
NEXT_PUBLIC_FIREBASE_VAPID_KEY=sua_chave_vapid_para_notificacoes

# CONFIGURAÇÃO DE IA (PRIVADO - LADO DO SERVIDOR)
# Obtenha em https://aistudio.google.com/
GOOGLE_API_KEY=sua_chave_google_ai_aqui
